# F5 Distributed Cloud – environment variables
# Copy this file to .env and fill in your values (never commit .env to git)

# Your F5 XC tenant name (the subdomain part of <tenant>.console.ves.volterra.io)
F5_XC_TENANT=my-tenant

# API Token generated in F5 XC Console → Administration → Credentials
F5_XC_API_TOKEN=your-api-token-here

# Default namespace used when none is selected
F5_XC_DEFAULT_NAMESPACE=default

# HTTP request timeout in seconds (default: 30)
F5_XC_TIMEOUT_SECONDS=30
